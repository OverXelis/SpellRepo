# ANTHROPIC_API_KEY=
# Required for Chat and Contemplate Meaning (batch generation).

# ANTHROPIC_MODEL=claude-sonnet-5
# Model for chat and batch generation (unless ANTHROPIC_BATCH_MODEL is set).

# ANTHROPIC_BATCH_MODEL=claude-haiku-4-5
# Optional: cheaper/faster model for batch generation only.

# APP_PASSWORD=
# Shared passphrase for the login gate. Strongly recommended for any host
# reachable beyond localhost. Leave unset for open local dev.

# DATABASE_PATH=./data/spell-atlas.db
# SQLite file path. Docker sets this to /data/spell-atlas.db automatically.
